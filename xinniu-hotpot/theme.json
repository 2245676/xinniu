{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "760px",
			"wideSize": "1180px"
		},
		"color": {
			"custom": true,
			"palette": [
				{
					"name": "Charcoal",
					"slug": "charcoal",
					"color": "#171412"
				},
				{
					"name": "Deep Wood",
					"slug": "deep-wood",
					"color": "#3A241B"
				},
				{
					"name": "Wine Red",
					"slug": "wine-red",
					"color": "#7D1F2D"
				},
				{
					"name": "Rice White",
					"slug": "rice-white",
					"color": "#F6F0E6"
				},
				{
					"name": "Champagne Gold",
					"slug": "champagne-gold",
					"color": "#C7A35A"
				}
			]
		},
		"typography": {
			"fluid": false,
			"fontFamilies": [
				{
					"name": "System Sans",
					"slug": "system-sans",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", \"Noto Sans JP\", \"Noto Sans SC\", sans-serif"
				},
				{
					"name": "Serif Display",
					"slug": "serif-display",
					"fontFamily": "\"Noto Serif JP\", \"Noto Serif SC\", Georgia, serif"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "0.875rem"
				},
				{
					"name": "Base",
					"slug": "base",
					"size": "1rem"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "1.25rem"
				},
				{
					"name": "Heading",
					"slug": "heading",
					"size": "2rem"
				}
			]
		},
		"spacing": {
			"units": [ "px", "rem", "%", "vw", "vh" ]
		}
	},
	"styles": {
		"color": {
			"background": "#F6F0E6",
			"text": "#171412"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-sans)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.7"
		},
		"elements": {
			"link": {
				"color": {
					"text": "#7D1F2D"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif-display)",
					"fontWeight": "600",
					"lineHeight": "1.25"
				}
			}
		}
	}
}

